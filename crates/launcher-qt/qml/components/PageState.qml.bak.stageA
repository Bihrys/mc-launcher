import QtQuick

QtObject {
    id: root

    property string key: ""
    property string title: ""
    property bool showBrand: false

    // HMCL DecoratorPage.State:
    // title / titleNode / backable / refreshable / animate / leftPaneWidth
    property bool backable: true
    property bool refreshable: false
    property bool animate: true
    property real leftPaneWidth: 0

    // HMCL Decorator 额外状态
    property bool closeable: false
    property bool showCloseAsHome: false
}
