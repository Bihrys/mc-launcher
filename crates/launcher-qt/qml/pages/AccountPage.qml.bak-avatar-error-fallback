                                    visible: root.loginMode === "yggdrasil"
                                    Layout.fillWidth: true
                                    style: root.style
                                    label: "密码"
                                    textValue: root.yggdrasilPassword
                                    placeholderText: "Password"
                                    password: true
                                    onEdited: function(value) {
                                        root.yggdrasilPassword = value
                                    }
                                }

                                ActionButton {
                                    visible: root.loginMode === "yggdrasil"
