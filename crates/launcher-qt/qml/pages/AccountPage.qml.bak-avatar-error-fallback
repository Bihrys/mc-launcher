            height: Math.min(root.height - 64, 420)
            radius: 8
            color: root.style.cSurfaceContainer
            border.color: root.style.cBorder
            border.width: 1

            ColumnLayout {
                anchors.fill: parent
                anchors.margins: 16
                spacing: 12

                Text {
                    Layout.fillWidth: true
                    text: "选择角色"
                    color: root.style.cTextOnSurface
                    font.pixelSize: 18
                    font.bold: true
                    elide: Text.ElideRight
