                set_current_account(self.as_mut(), &account);
                refresh_accounts_property(self.as_mut());

                self.as_mut().set_output(QString::from(&format!(
                    "微软账户登录完成，并已切换到该账户。\n\n角色名: {}\nUUID: {}\n{}\n\n账户文件:\n{}",
                    account.username,
                    account.uuid,
                    account.note.unwrap_or_default(),
                    path.display()
                )));
